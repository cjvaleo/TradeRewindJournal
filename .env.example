# Rewind · environment variables
# Copy this file to .env.local and fill in real values for local dev.
# Production values live in Vercel → Project → Settings → Environment Variables.
# .env.local is gitignored — never commit secrets.

# ── Site ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://traderewindjournal.com

# ── Encryption + cron ───────────────────────────────────────────
# Generate each with: openssl rand -hex 32
# Save ENCRYPTION_KEY in 1Password — losing it bricks every linked Discord.
ENCRYPTION_KEY=
CRON_SECRET=

# ── Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# server-only — never send to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ──────────────────────────────────────────────────────
# Use sk_test_… in dev/preview, sk_live_… in production.
STRIPE_SECRET_KEY=sk_test_...
# Different per environment. Get from Stripe → Webhooks → endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_DIRECT_ID=price_...
STRIPE_PRICE_PREMIUM_ID=price_...
STRIPE_COUPON_50_OFF_3MO=save_50_3mo

# ── Discord ─────────────────────────────────────────────────────
# NOTE: No DISCORD_BOT_TOKEN — we use user OAuth refresh tokens for the
# daily role-check cron because we don't own the Trading Ark server.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
TRADING_ARK_GUILD_ID=
TRADING_ARK_PREMIUM_ROLE_ID=
TRADING_ARK_ELITE_ROLE_ID=

# ── Resend ──────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM_NAME=Christian from Rewind
EMAIL_FROM_ADDRESS=hello@traderewindjournal.com

# ── Whop (affiliate URLs, can also be hardcoded in app constants) ─
NEXT_PUBLIC_WHOP_PREMIUM_URL=https://whop.com/checkout/plan_tRNqykRyLXsKv?a=christianvaleo
NEXT_PUBLIC_WHOP_ELITE_URL=https://whop.com/checkout/plan_KY7CY81vHFic1?a=christianvaleo
